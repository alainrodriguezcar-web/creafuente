# Copia este archivo a .env y rellena los valores

# Railway te provee esta variable automáticamente al agregar PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/handtype

# URL de tu frontend en Vercel (sin trailing slash)
FRONTEND_URL=https://handtype.vercel.app

# 'production' | 'development'
NODE_ENV=production

# Puerto (Railway lo setea automáticamente)
PORT=3001
